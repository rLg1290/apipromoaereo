# ── Telegram MTProto (obrigatório) ────────────────────────────────────────────
# Obtenha em: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Username ou ID numérico do grupo (ex: @balcaomilhas ou -1001234567890)
TELEGRAM_GROUP=

# Gerado pelo script generate_session.py — obrigatório no Docker/VPS
TELEGRAM_SESSION_STRING=

# ── Banco de dados ────────────────────────────────────────────────────────────
# Em Docker, o docker-compose.yml já define /app/data/promotions.db
DB_PATH=promotions.db

# ── Desenvolvimento local (opcional) ─────────────────────────────────────────
# Usado apenas quando TELEGRAM_SESSION_STRING está vazio (autenticação interativa)
SESSION_NAME=promo_session
